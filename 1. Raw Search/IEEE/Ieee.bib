@inproceedings{Kaur2025,
  title = {Maternal risk prediction by early detection of Pre-Eclampsia and high-risk pregnancies using machine learning},
  url = {http://dx.doi.org/10.1109/ESIC64052.2025.10962644},
  DOI = {10.1109/esic64052.2025.10962644},
  booktitle = {2025 International Conference on Emerging Systems and Intelligent Computing (ESIC)},
  publisher = {IEEE},
  author = {Kaur,  Manpreet and R.Girija and Singh,  Maneesha and Gupta,  Tanvi and Marwaha,  Shreya},
  year = {2025},
  month = feb,
  pages = {238–244},
abstract={After 20 weeks of pregnancy, pre-eclampsia, a severe pregnancy syndrome, usually manifests as increased blood pressure and injury to other organs. In order to prevent adverse consequences for both the mother and the fetus, early detection and forecasting are essential for prompt intervention and therapy. Machine learning techniques are highly effective tools for predictive analytics in the healthcare industry, with the ability to identify high-risk pregnancies and enhance clinical decision-making. In this study, it has been suggested that machine learning be used to forecast pre-eclampsia by utilizing clinical and perinatal demographic information. We use a dataset containing information on maternal age, blood pressure readings, and other relevant parameters to train and evaluate predictive models. Artificial neural networks were found to be the most effective approach, achieving an accuracy of 75%, demonstrating their potential in accurately predicting pre-eclampsia and supporting timely medical interventions.}
}
@inproceedings{Asadi2023,
  title = {Database Design for Pre-Eclampsia Case Administration},
  url = {http://dx.doi.org/10.1109/ICITDA60835.2023.10426919},
  DOI = {10.1109/icitda60835.2023.10426919},
  booktitle = {2023 8th International Conference on Information Technology and Digital Applications (ICITDA)},
  publisher = {IEEE},
  author = {Asadi,  Faisal and Elwirehardja,  Gregorius Natanael and Trinugroho,  Joko Pebrianto and Rahutomo,  Reza and Pardamean,  Bens},
  year = {2023},
  month = nov,
  pages = {1–6},
abstract={The Ministry of Health of Indonesia has referred to pre-eclampsia as one of the most severe diseases affecting women. As an urgency, it is crucial to administrate pre-eclampsia cases for disease prevention as a long-term national healthcare strategy. Regarding health science, case data was significant in developing research and innovation. However, the main problem regarding pre-eclampsia case administration is data handling, recording, and management incompetence. Hence, this research proposed a conceptual design of a database for pre-eclampsia case administration. The proposed design covered conceptual, logical, and physical design. We elaborate the concept into three concepts of pre-eclampsia disease: pre-treatment, treatment, and post-treatment. This study proposed a solution to gain more data and study pre-eclampsia disease in Indonesia.}
}
@inproceedings{Loftness2023,
  title = {Preterm Preeclampsia Risk Modelling: Examining Hemodynamic,  Biochemical,  and Biophysical Markers Prior to Pregnancy},
  url = {http://dx.doi.org/10.1109/EMBC40787.2023.10340404},
  DOI = {10.1109/embc40787.2023.10340404},
  booktitle = {2023 45th Annual International Conference of the IEEE Engineering in Medicine &amp; Biology Society (EMBC)},
  publisher = {IEEE},
  author = {Loftness,  Bryn C. and Bernstein,  Ira and McBride,  Carole A. and Cheney,  Nick and McGinnis,  Ellen W. and McGinnis,  Ryan S.},
  year = {2023},
  month = jul,
  pages = {1–4},
abstract = {Preeclampsia (PE) is a leading cause of maternal and perinatal death globally and can lead to unplanned preterm birth. Predicting risk for preterm or early-onset PE, has been investigated primarily after conception, and particularly in the early and mid-gestational periods. However, there is a distinct clinical advantage in identifying individuals at risk for PE prior to conception, when a wider array of preventive interventions are available. In this work, we leverage machine learning techniques to identify potential pre-pregnancy biomarkers of PE in a sample of 80 women, 10 of whom were diagnosed with preterm preeclampsia during their subsequent pregnancy. We explore prospective biomarkers derived from hemodynamic, biophysical, and biochemical measurements and several modeling approaches. A support vector machine (SVM) optimized with stochastic gradient descent yields the highest overall performance with ROC AUC and detection rates up to .88 and .70, respectively on subject-wise cross validation. The best performing models leverage biophysical and hemodynamic biomarkers. While preliminary, these results indicate the promise of a machine learning based approach for detecting individuals who are at risk for developing preterm PE before they become pregnant. These efforts may inform gestational planning and care, reducing risk for adverse PE-related outcomes.Clinical Relevance— This work considers the development and optimization of pre-pregnancy biomarkers for improving the identification of preterm (early-onset) preeclampsia risk prior to conception.}
}
@inproceedings{Badriyah2018,
  title = {Predicting The Risk of Preeclampsia with History of Hypertension Using Logistic Regression and Naive Bayes},
  url = {http://dx.doi.org/10.1109/iCAST1.2018.8751588},
  DOI = {10.1109/icast1.2018.8751588},
  booktitle = {2018 International Conference on Applied Science and Technology (iCAST)},
  publisher = {IEEE},
  author = {Badriyah,  Tessy and Tahrir,  Muhlis and Syarif,  Iwan},
  year = {2018},
  month = oct,
  pages = {399–403}, 
  abstract = {The causes of maternal and infant mortality are high, especially in developing countries other than bleeding, namely preeclampsia because mild preeclampsia increases more sharply than severe preeclampsia. The incidence of preeclampsia varies in each country even in every region. The purpose of this study was to compare two methods in data mining techniques, namely the Logistic Regression method and the Naive Bayes method, to predict the risk level of Preeclampsia on the seventeen existing attributes data. The data obtained in this study were 239 preeclampsia patients who were obtained from Surabaya General Hajj Hospital, by collecting data from 2016 to 2017. This study used performance measurement of the two methods using score with the ROC curve (Receiver Operating Characteristics). In the experimental results, we found that in the term of accuracy and ROC curve, Logistic Regression has a slightly better performance than the Naive Bayes method.}

}
@inproceedings{Simbolon2020,
  title = {Predicting the Risk of Preeclampsia using Soft Voting-based Ensemble and Its Recommendation},
  url = {http://dx.doi.org/10.1109/CcS49175.2020.9231400},
  DOI = {10.1109/ccs49175.2020.9231400},
  booktitle = {2020 International Symposium on Community-centric Systems (CcS)},
  publisher = {IEEE},
  author = {Simbolon,  Oknalita and Widyawati,  Melyana Nurul and Kurnianingsih,  Kurnianingsih and Kubota,  Naoyuki and Ng,  Nawi},
  year = {2020},
  month = sep,
  pages = {1–6},
abstract = {Preeclampsia is one of the leading causes of maternal deaths and pregnancy-related complications in many low-income countries. Factors related to preeclampsia include lack of prenatal care and access to medical services, lack of facilities, and inadequate diagnosis and treatment of preeclampsia patients. Early detection and prompt treatment of preeclampsia are essential for the prevention of eclampsia and other life-threatening complications. Several studies have developed the risk prediction models for preeclampsia using mobile applications and machine learning techniques. The use of a soft voting-based ensemble method and recommendation system for women at high risk of preeclampsia remains unexplored. We developed a mobile application with two functionalities of preeclampsia prediction and recommendation system for women at high risk of preeclampsia. We employed the soft voting ensemble learning for the preeclampsia prediction. We obtained a high accuracy value of 98.51% ± 0.0186% compared to the six individual classifiers (k-Nearest Neighbors, Linear SVM, RBF SVM, Gaussian Process, Multi-Layer Perceptron, and Ada Boost). Our proposed recommender system also yielded in a high accuracy value of 96.66% ± 0.0229%. Both our proposed ensemble based on soft-voting and recommendation system had small variance values, which indicated high stability}
}
@inproceedings{ChavezLeyva2021,
  title = {Characterization of systolic and diastolic pressure time series in pregnant women with preeclampsia through symbolic dynamics},
  url = {http://dx.doi.org/10.1109/EMBC46164.2021.9630136},
  DOI = {10.1109/embc46164.2021.9630136},
  booktitle = {2021 43rd Annual International Conference of the IEEE Engineering in Medicine &amp; Biology Society (EMBC)},
  publisher = {IEEE},
  author = {Chavez-Leyva,  Daniel and Dorantes-Mendez,  Guadalupe and Alvarado-Jalomo,  Samantha and Camargo-Marin,  Lisbeth and Gaitan-Gonzalez,  Mercedes J.},
  year = {2021},
  month = nov,
  pages = {5638–5641},
abstract = {Preeclampsia (PE) is one of the leading causes of maternal mortality worldwide. Although clinical strategies to prevent the early onset of PE have been proposed, the ultimate solution is to end the pregnancy. Therefore, patients’ identification with major PE risk is important towards the prevention and better management of a severe manifestation of the illness. This study aims to analyze the systolic blood pressure (SBP) and diastolic blood pressure (DBP) time series through a nonlinear perspective using symbolic dynamics and to incorporate a multi-scale assessment in the first trimester of pregnancy, previous to the clinical manifestation of PE. The study group of normotensive women who developed and were diagnosed with PE included 14 pregnant women, a normotensive throughout pregnancy control group (N) consisting of 14 participants, and a group of 14 normotensive women during pregnancy without comorbidities (S) were matched with PE by age, body mass index, gestational age and comorbidities. The preliminary results of this study showed a decreased complexity of SBP, assessed by multiscale symbolic entropy in the first trimester in PE patients, in comparison with normotensive pregnant women.Clinical relevance— This work shows how nonlinear analysis of systolic and diastolic blood pressure time series are useful to detect preeclampsia in the first trimester of pregnancy.}
}

@inproceedings{Carreno2020,
  title = {Feature selection algorithms for predicting preeclampsia: A comparative approach},
  url = {http://dx.doi.org/10.1109/BIBM49941.2020.9313108},
  DOI = {10.1109/bibm49941.2020.9313108},
  booktitle = {2020 IEEE International Conference on Bioinformatics and Biomedicine (BIBM)},
  publisher = {IEEE},
  author = {Carreno,  Jose F and Qiu,  Peng},
  year = {2020},
  month = dec,
  pages = {2626–2631},
abstract = {Preeclampsia is a disease that complicates a large number of pregnancies. In this study, a comparative approach is taken to understand how dimension reduction methods and time-series summary methods can be useful for predicting preeclampsia based on proteomics data. Here, the dimension reduction methods are the Imperialist Competitive Algorithm and the gene clustering method of the Sample Progression Discovery algorithm, the time-series summary methods included a simple overall average and a 3-point summary corresponding to the three trimesters of pregnancy. These approaches achieved similar prediction accuracy around 90% in two independent datasets. Separate analysis of data from each trimester showed an interesting result that it is easier to predict preeclampsia based on proteomics data of the first two trimesters of pregnancy rather than the last trimester.}
}
@inproceedings{Maheswari2024,
  title = {Analysis and Detection of Preeclampsia Using Machine Learning Techniques},
  url = {http://dx.doi.org/10.1109/ICSCNA63714.2024.10864251},
  DOI = {10.1109/icscna63714.2024.10864251},
  booktitle = {2024 International Conference on Sustainable Communication Networks and Application (ICSCNA)},
  publisher = {IEEE},
  author = {Maheswari,  S. and Manju,  E. and V,  Loganathan and Ponkarthika,  M. and Saranya,  M. and Govindaraj,  S.},
  year = {2024},
  month = dec,
  pages = {978–983},
abstract = {Preeclampsia is a significant pregnancy complication marked by elevated blood pressure and the possibility of harm to various organs, posing risks to both the mother and the baby. Preeclampsia is a dangerous pregnancy complication that can harm other organs and raise blood pressure, endangering both the mother and the fetus. To improve outcomes for mothers and newborns, preeclampsia must be identified early and treated appropriately. This study proposes a hyperparameter-tuned K-Nearest Neighbors (KNN) classification model as a potential means of diagnosing preeclampsia. To effectively forecast the possibility of preeclampsia the model utilizes several clinical factors, such as blood pressure, body mass index (BMI), number of pregnancies, placental location, uterine artery pulsatility index (UTPI), and ultrasound imaging of the placenta. There are various important phases to this endeavor. First, a comprehensive dataset comprising patient records is preprocessed, standardizing continuous variables and encoding categorical variables. Next, to enhance the model's performance, adjustments to the KNN classifier are made based on research that methodically examines several hyperparameters like the number of neighbors, distance metrics, and weight functions. To enhance model performance, it's beneficial to utilize weight functions and various distance metrics. Metrics such as accuracy, precision, recall, F1 score, and the receiver operating characteristic (ROC) curve are employed to evaluate the enhanced model. In order to make real-time forecasts and enable healthcare practitioners to input patient data, a user-friendly interface has been built. Thorough testing is used to confirm the system's capacity to handle novel and unseen data, guaranteeing generalizability and reliability. With a reliable method for anticipating and treating this serious illness, this preeclampsia detection model seeks to promote early diagnosis, prompt intervention, and enhanced patient care.}
}
@inproceedings{Marin2019,
  title = {Early Detection of Preeclampsia based on a Machine Learning Approach},
  url = {http://dx.doi.org/10.1109/EHB47216.2019.8970025},
  DOI = {10.1109/ehb47216.2019.8970025},
  booktitle = {2019 E-Health and Bioengineering Conference (EHB)},
  publisher = {IEEE},
  author = {Marin,  Iuliana and Pavaloiu,  Bujorel-Ionel and Marian,  Constantin-Viorel and Racovita,  Vlad and Goga,  Nicolae},
  year = {2019},
  month = nov,
  pages = {1–4},
abstract = {Preeclampsia is one of the death causes of pregnant women and their unborn children. Preventive measures should be taken for detecting the illness as early as possible. The current paper determines the presence of preeclampsia using a non-invasive approach. The blood pressure measurements are generated using a smart bracelet which is part of the i-bracelet Eurostars project, "Intelligent bracelet for blood pressure monitoring and detection of preeclampsia". The considered input data are the age, weight and blood pressure measurements of every pregnant woman. The prediction model comprised a series of hidden states. The Viterbi algorithm was used to determine the presence of a certain hidden state, namely preeclampsia. The accuracy, sensitivity and specificity values of the tested solution prove that it is useful in remote and hospital settings.}
}
@inproceedings{Devi2023,
  title = {Prediction of Hypertensive Disorders in Pregnancy using Machine Learning Algorithms},
  url = {http://dx.doi.org/10.1109/ICSES60034.2023.10465376},
  DOI = {10.1109/icses60034.2023.10465376},
  booktitle = {2023 International Conference on Innovative Computing,  Intelligent Communication and Smart Electrical Systems (ICSES)},
  publisher = {IEEE},
  author = {Devi,  Seeta and Wagle,  Shivali Amit},
  year = {2023},
  month = dec,
  pages = {1–6},
abstract = {Objective 
The primary objective of this study was to evaluate the efficacy of the HDP gestosis score by adopting Machine Learning Algorithms (MLA) to predict preeclampsia.
Methods
The information was gathered retrospectively by reviewing the patient’s records. The HDP Gestosis Score predictors were evaluated for their ability to predict preeclampsia. The following machine learning models were utilized in this study: XG Boost classifier, Naive Bayes classifier, Support Vector Machine (SVM), RF classifier, and Decision Tree to evaluate the predictive efficiency of the HDP factors in predicting hypertensive diseases during pregnancy.
Results
Approximately 55% of women were assessed as being at high risk for preeclampsia, 17% at low risk, and the rest at moderate risk. Compared to other models, Naive Bayes (NB) and Random forest classifier performed better for prediction of women at risk for preeclampsia. The precision and accuracy of NB were 0.97 and 0.96, respectively, with an AUC of 0.96. The precision and specificity of RF were 0.88 and 1.0; correspondingly, with an AUC of 0.82, both models demonstrated greater under the ROC curve values.
Conclusion
Gestosis score and the MLA are effective models for predicting preeclampsia.}
}

@inproceedings{Mohan2024,
  title = {Predicting and Monitoring of Preeclampsia: An Evaluation with Machine Learning Techniques},
  url = {http://dx.doi.org/10.1109/ICACCS60874.2024.10716889},
  DOI = {10.1109/icaccs60874.2024.10716889},
  booktitle = {2024 10th International Conference on Advanced Computing and Communication Systems (ICACCS)},
  publisher = {IEEE},
  author = {Mohan,  Jinu and Ali,  Anooja and PS,  Ambili and Ali,  Axina},
  year = {2024},
  month = mar,
  pages = {1062–1067},
abstract = {Preeclampsia (PE) emerges following the first 20 weeks of pregnancy, marked by the presence of proteinuria and hypertension. This condition is linked to placental dysfunction and hypertension induced due to pregnancy. It can impact both maternal health and fetal growth, potentially leading to low birth weights - a factor contributing to the risk of neonatal mortality. Hypertensive disorders during pregnancy impact about 10% of global pregnancies. Within this examination, we delve into the involvement of Machine Learning (ML) techniques in forecasting PE. This review seeks to offer a brief summary of recent advancements in predicting, diagnosing, and monitoring PE through ML algorithms by examining the potential implications through stemming from the capability of various ML algorithms (RF, DT, LR, SVM). In the proposed model 14 factors were included, such as maternal traits, health history, prenatal test results, and ultrasound findings. Cross-validation is used to assess the differentiation, and area under the receiver operating curve (AUROC) is observed. Hence, the ML techniques (SVM, LR, DT and RF) were executed, and patient-centric healthcare information on PE can be effectively retrieved using Random Forest (RF).}
}
@inproceedings{Wanriko2021,
  title = {Risk Assessment of Pregnancy-induced Hypertension Using a Machine Learning Approach},
  url = {http://dx.doi.org/10.1109/ECTIDAMTNCON51128.2021.9425764},
  DOI = {10.1109/ectidamtncon51128.2021.9425764},
  booktitle = {2021 Joint International Conference on Digital Arts,  Media and Technology with ECTI Northern Section Conference on Electrical,  Electronics,  Computer and Telecommunication Engineering},
  publisher = {IEEE},
  author = {Wanriko,  Sirinat and Hnoohom,  Narit and Wongpatikaseree,  Konlakom and Jitpattanakul,  Anuchit and Musigavong,  Olarik},
  year = {2021},
  month = mar,
  pages = {233–237},
abstract = {This research aimed to develop a predictive model of the risk assessment of pregnancy-induced hypertension using a machine learning approach. Pregnancy-induced hypertension is a complication that has a serious impact on pregnant women and fetuses. It is the world's top three cause of death among pregnant women [1]. Nowadays, the exact cause of pregnancy-induced hypertension is unknown and therefore cannot be prevented. Early detection and received treatment can reduce the severity and danger. A public dataset of Logan (2020) was used in this research [2]. The dataset was collected from a casecontrol study on the determinants of 83 pre-eclampsia and five eclampsia cases among 352 pregnant women delivering in county hospitals in Nairobi, Kenya. According to the dataset, 75 percent of the pregnant women were healthy. Only 25 percent of the pregnant women were pre-eclampsia and eclampsia. Thus, this would result in a problem of an imbalanced classification when one of the two classes had more data than the other class. As such, this problem was resolved with the Synthetic Minority Over-sampling Technique (SMOTE). Risk assessment of pregnancy-induced hypertension was performed on seven machine learning algorithms, which were logistic regression (LR), K-nearest neighbor (KNN), decision tree (DT), random forest (RF), multilayer perceptron neural network(MLP), support vector machines (SVM), and naive Bayes (NB). In the experimental results, RF had the highest accuracy at 89.62 percent compared to other machine learning algorithms}
}
@inproceedings{ParralesBravo2024,
  title = {Prediction of Emergency Room Arrivals of Patients with Preeclampsia Disease Using Artificial Neural Network Model},
  url = {http://dx.doi.org/10.1109/ICEIB61477.2024.10602647},
  DOI = {10.1109/iceib61477.2024.10602647},
  booktitle = {2024 IEEE 4th International Conference on Electronic Communications,  Internet of Things and Big Data (ICEIB)},
  publisher = {IEEE},
  author = {Parrales–Bravo,  Franklin and Caicedo–Quiroz,  Rosangela and Barzola–Monteses,  Julio and Cevallos–Torres,  Lorenzo},
  year = {2024},
  month = apr,
  pages = {34–39},
abstract = {The administration of a country's public health is an essential issue. Conversely, preeclampsia ranks among the most frequent causes of maternal fatalities during pregnancy. Moreover, as in many nations, emergency rooms are severely overcrowded. Thus, we enhanced the management of Emergency Care for Preeclampsia at the “IESS Hospital del Día Sur Valdivia” so as not to risk the patients' lives. Techniques such as Extreme Learning Machine (ELM), Multilayer Perceptron (MLP), and Dynamic Bayesian Networks (DBN) were used to train the forecasting models. Mean Absolute Percentage Error (MAPE), Root-mean-square error (RMSE), and Mean Absolute Error (MAE) metrics were used to assess the model's performance. The model with the lowest MAPE value was chosen among the trained models. The model trained with MLP achieved the lowest MAPE, whose value was 17.21%. This model also achieved an RMSE of 4.21 and a MAE of 2.74. According to the MLP model, 11 to 13 emergency arrivals due to preeclampsia were predicted for September to November of 2024 in the “IESS Hospital del Día Sur Valdivia”, i.e., AI models foresee the hospital's medical needs for timely management of patients with this disease}
}

@inproceedings{Aruna2024,
  title = {Emerging Trends and Obstacles in Predicting Preeclampsia: A Comprehensive Review of Machine Learning and Deep Learning Techniques},
  url = {http://dx.doi.org/10.1109/ICESIC61777.2024.10846126},
  DOI = {10.1109/icesic61777.2024.10846126},
  booktitle = {2024 International Conference on Electronic Systems and Intelligent Computing (ICESIC)},
  publisher = {IEEE},
  author = {Aruna,  R. and Sivaranjani,  S.},
  year = {2024},
  month = nov,
  pages = {314–318},
abstract = {Preeclampsia, a serious hypertension condition during pregnancy, presents considerable hazards to both mother and fetal health, potentially resulting in catastrophic consequences if not promptly identified. Conventional diagnostic techniques depend on clinical evaluations and biomarkers, which may not consistently provide prompt or precise predictions. Recently, deep learning algorithms have emerged as potent instruments for studying intricate, high-dimensional data, potentially improving illness prediction by uncovering patterns and features overlooked by traditional methods. Recent research reveals the advancement of several machine learning and deep learning models for predicting preeclampsia from 2021 to 2024, employing a wide array of input data, including maternal demographics, clinical histories, and ultrasound pictures. Research has indicated favorable outcomes, with these models exhibiting enhanced sensitivity, specificity, and overall accuracy relative to conventional methods. Nonetheless, obstacles persist in domains such as data integrity, model interpretability, and the applicability of findings across varied populations. This literature review highlights recent developments in deep learning methodologies for the detection of preeclampsia and examines potential enhancements for practical use. Keywords include preeclampsia, maternal demographics, clinical evaluations, biomarkers, ultrasound imaging, and fetal health.}
}

@inproceedings{Roque2024,
  title = {Forecasting Risk Pregnancies in Peru using Machine Learning},
  url = {http://dx.doi.org/10.1109/ICOA62581.2024.10753982},
  DOI = {10.1109/icoa62581.2024.10753982},
  booktitle = {2024 10th International Conference on Optimization and Applications (ICOA)},
  publisher = {IEEE},
  author = {Roque,  Airton and Huamanzana,  Joel and Mauricio,  David},
  year = {2024},
  month = oct,
  pages = {1–6},
abstract = {In Peru, between 2017 and 2021, there has been an upward trend in maternal deaths attributed to preeclampsia, reaching an average of 393 cases. Recognizing the importance of early detection of risks associated with preeclampsia, a predictive model was developed using machine learning techniques to forecast pregnancies at risk of preeclampsia. Six models (Support Vector Machine, C5.0 Algorithm, Classification and Regression Trees, k-Nearest Neighbors, Naive Bayes, Logistic Regression) were employed on 44,633 records analyzed from an obstetrics section located in a hospital in Peru, with 11 out of 24 variables selected, including laboratory tests. Logistic Regression demonstrated the best performance, achieving an AUC of 97.6% and an accuracy of 81.8%. This model has the potential to be implemented in hospital settings to detect preeclampsia early, which could significantly contribute to reducing maternal and neonatal mortality rates in the country.}
}
